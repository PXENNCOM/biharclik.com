# Backend/.env.example
# Server Configuration
NODE_ENV=development
PORT=3001

# Database Configuration
# Prod Aşamasına DB_HOST "mysql" olarak değiştir!!!! Locale çekersen "localhost" yap
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=123456
DB_NAME=dernek_system
DB_PORT=3307  # MySQL'in varsayılan portu Prod için 3306 olmalı, localde 3307

# JWT Configuration
JWT_ACCESS_SECRET=your-super-secret-access-key-change-this
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Email Configuration (Sonra eklenecek)
EMAIL_HOST=
EMAIL_PORT=
EMAIL_USER=
EMAIL_PASSWORD=

# SMS Configuration (Sonra eklenecek)
SMS_API_KEY=
SMS_API_SECRET=

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100
